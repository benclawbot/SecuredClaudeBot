{
  "name": "fastbot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Ultra-secure personal AI gateway — Telegram + Mission Control dashboard",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "doctor": "pnpm --filter @fastbot/gateway run doctor",
    "dashboard": "pnpm --filter @fastbot/dashboard run dev",
    "gateway": "pnpm --filter @fastbot/gateway run dev",
    "playwright": "pnpm --filter @fastbot/playwright run dev",
    "start": "pnpm -r --parallel run start",
    "setup": "pnpm install && pnpm build",
    "launch": "node scripts/launch.js"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "canvas",
      "esbuild",
      "sharp",
      "sqlite3",
      "tesseract.js"
    ],
    "overrides": {
      "zod": "^3.23.8",
      "tar": "^7.4.0",
      "axios": "^1.7.9",
      "xlsx": "^0.18.5",
      "expr-eval": "^2.0.2"
    }
  },
  "devDependencies": {
    "pm2": "^6.0.14",
    "tsx": "^4.21.0"
  }
}